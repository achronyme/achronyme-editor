{
  "name": "achronyme",
  "displayName": "Achronyme",
  "description": "Language support for Achronyme (.ach) and imported Circom (.circom) — ZK cryptography DSL",
  "version": "0.2.0-beta.21",
  "license": "Apache-2.0",
  "publisher": "eddndev",
  "icon": "icons/achronyme.png",
  "homepage": "https://achrony.me",
  "bugs": {
    "url": "https://github.com/achronyme/achronyme-editor/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/achronyme/achronyme-editor"
  },
  "keywords": [
    "achronyme",
    "circom",
    "zero-knowledge",
    "zk",
    "zk-snark",
    "groth16",
    "halo2",
    "cryptography",
    "dsl"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:achronyme",
    "onLanguage:circom"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "achronyme",
        "aliases": [
          "Achronyme",
          "ach"
        ],
        "extensions": [
          ".ach"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "circom",
        "aliases": [
          "Circom",
          "circom"
        ],
        "extensions": [
          ".circom"
        ],
        "configuration": "./language-configuration-circom.json"
      }
    ],
    "grammars": [
      {
        "language": "achronyme",
        "scopeName": "source.ach",
        "path": "./syntaxes/achronyme.tmLanguage.json"
      },
      {
        "language": "circom",
        "scopeName": "source.circom",
        "path": "./syntaxes/circom.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "achronyme.run",
        "title": "Run Achronyme File",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "achronyme.run",
          "when": "resourceLangId == achronyme && resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "title": "Achronyme",
      "properties": {
        "achronyme.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to the Achronyme CLI (ach) binary. Leave empty to use the bundled or auto-downloaded binary."
        },
        "achronyme.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Achronyme Language Server (ach-lsp) binary. Leave empty to use the bundled binary."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
