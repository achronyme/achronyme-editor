{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Achronyme",
  "scopeName": "source.ach",
  "patterns": [
    { "include": "#comments" },
    { "include": "#import-statement" },
    { "include": "#strings" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#prove-block" },
    { "include": "#keywords" },
    { "include": "#function-definition" },
    { "include": "#builtins" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ach",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ach",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "import-statement": {
      "patterns": [
        {
          "comment": "Selective import: import { x, y } from \"path\"",
          "begin": "\\b(import)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.control.import.ach" },
            "2": { "name": "punctuation.definition.block.ach" }
          },
          "end": "(\\})\\s+(from)\\s+(\"[^\"]*\")",
          "endCaptures": {
            "1": { "name": "punctuation.definition.block.ach" },
            "2": { "name": "keyword.control.from.ach" },
            "3": { "name": "string.quoted.double.ach" }
          },
          "patterns": [
            {
              "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
              "name": "variable.other.import.ach"
            },
            {
              "match": ",",
              "name": "punctuation.separator.comma.ach"
            }
          ]
        },
        {
          "comment": "Namespace import: import \"path\" as alias",
          "match": "\\b(import)\\s+(\"[^\"]*\")\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.import.ach" },
            "2": { "name": "string.quoted.double.ach" },
            "3": { "name": "keyword.control.as.ach" },
            "4": { "name": "entity.name.namespace.ach" }
          }
        },
        {
          "comment": "Export list: export { x, y }",
          "begin": "\\b(export)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.control.export.ach" },
            "2": { "name": "punctuation.definition.block.ach" }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": { "name": "punctuation.definition.block.ach" }
          },
          "patterns": [
            {
              "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
              "name": "variable.other.export.ach"
            },
            {
              "match": ",",
              "name": "punctuation.separator.comma.ach"
            }
          ]
        },
        {
          "comment": "Inline export keyword",
          "match": "\\b(export)\\b",
          "name": "keyword.control.export.ach"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ach",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ach",
              "match": "\\\\[\"\\\\nrtbf/]"
            }
          ]
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.ach",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.field.ach",
          "match": "\\b0p(x[0-9a-fA-F]+|b[01]+|[0-9]+)\\b"
        },
        {
          "name": "constant.numeric.bigint.ach",
          "match": "\\b0i(256|512)(x[0-9a-fA-F]+|d[0-9]+|b[01]+)\\b"
        },
        {
          "name": "constant.numeric.integer.ach",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ach",
          "match": "\\b(if|else|while|for|in|return|break|continue|forever)\\b"
        },
        {
          "name": "keyword.other.ach",
          "match": "\\b(let|mut|fn|public|witness|prove)\\b"
        }
      ]
    },
    "prove-block": {
      "comment": "prove(public: [name1, name2]) { ... } syntax",
      "begin": "\\b(prove)\\s*(\\()\\s*(public)\\s*(:)\\s*(\\[)",
      "beginCaptures": {
        "1": { "name": "keyword.other.ach" },
        "2": { "name": "punctuation.section.parens.begin.ach" },
        "3": { "name": "keyword.other.ach" },
        "4": { "name": "punctuation.separator.colon.ach" },
        "5": { "name": "punctuation.section.brackets.begin.ach" }
      },
      "end": "(\\])\\s*(\\))",
      "endCaptures": {
        "1": { "name": "punctuation.section.brackets.end.ach" },
        "2": { "name": "punctuation.section.parens.end.ach" }
      },
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "name": "variable.parameter.public-input.ach"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.ach"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "comment": "Global functions (called as name(args))",
          "name": "support.function.builtin.ach",
          "match": "\\b(print|typeof|assert|time|gc_stats|proof_json|proof_public|proof_vkey|poseidon|poseidon_many|verify_proof|bigint256|bigint512|from_bits|parse_int|join)\\b(?=\\s*\\()"
        },
        {
          "comment": "Static namespace access (Type::MEMBER)",
          "match": "\\b(Int|Field|BigInt)(::)(MAX|MIN|ZERO|ONE|ORDER|from_bits)\\b",
          "captures": {
            "1": { "name": "support.type.ach" },
            "2": { "name": "punctuation.accessor.double-colon.ach" },
            "3": { "name": "support.constant.ach" }
          }
        },
        {
          "comment": "Method calls (.method(args))",
          "match": "\\.(len|push|pop|keys|values|entries|contains_key|get|set|remove|map|filter|reduce|for_each|find|any|all|sort|flat_map|zip|abs|min|max|pow|to_field|to_string|to_int|to_bits|to_upper|to_lower|starts_with|ends_with|contains|split|trim|replace|chars|index_of|substring|repeat|bit_and|bit_or|bit_xor|bit_not|bit_shl|bit_shr)\\s*(?=\\()",
          "captures": {
            "1": { "name": "support.function.method.ach" }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.ach" },
            "2": { "name": "entity.name.function.ach" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.ach" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.ach",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.ach",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.ach",
          "match": "\\+|-|\\*|/|%|\\^"
        },
        {
          "name": "keyword.operator.assignment.ach",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.ach",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.ach",
          "match": "\\.\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.ach",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.ach",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.semicolon.ach",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.ach",
          "match": "\\."
        }
      ]
    }
  }
}
