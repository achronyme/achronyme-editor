{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Circom",
  "scopeName": "source.circom",
  "patterns": [
    { "include": "#comments" },
    { "include": "#pragma" },
    { "include": "#include" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#template-definition" },
    { "include": "#function-definition" },
    { "include": "#main-component" },
    { "include": "#signal-declaration" },
    { "include": "#component-declaration" },
    { "include": "#keywords" },
    { "include": "#constraint-operators" },
    { "include": "#operators" },
    { "include": "#builtins" },
    { "include": "#function-call" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.circom", "match": "//.*$" },
        { "name": "comment.block.circom", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "pragma": {
      "patterns": [
        {
          "comment": "pragma circom 2.x.y;",
          "match": "\\b(pragma)\\s+(circom|custom_templates)\\b([^;]*)",
          "captures": {
            "1": { "name": "keyword.control.pragma.circom" },
            "2": { "name": "keyword.other.pragma-name.circom" },
            "3": { "name": "constant.numeric.version.circom" }
          }
        }
      ]
    },
    "include": {
      "patterns": [
        {
          "match": "\\b(include)\\s+(\"[^\"]*\")\\s*;",
          "captures": {
            "1": { "name": "keyword.control.include.circom" },
            "2": { "name": "string.quoted.double.circom" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.circom",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.circom", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.circom", "match": "\\b0[xX][0-9a-fA-F_]+\\b" },
        { "name": "constant.numeric.decimal.circom", "match": "\\b[0-9][0-9_]*\\b" }
      ]
    },
    "template-definition": {
      "patterns": [
        {
          "comment": "template Name(args) { ... }",
          "match": "\\b(template)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.other.template.circom" },
            "2": { "name": "entity.name.type.template.circom" }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "comment": "function nbits(x) { ... }",
          "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.other.function.circom" },
            "2": { "name": "entity.name.function.circom" }
          }
        }
      ]
    },
    "main-component": {
      "patterns": [
        {
          "comment": "component main = Template(...);",
          "match": "\\b(component)\\s+(main)(?:\\s*\\{[^}]*\\})?\\s*=\\s*([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.component.circom" },
            "2": { "name": "entity.name.main.circom" },
            "3": { "name": "entity.name.type.template.circom" }
          }
        }
      ]
    },
    "signal-declaration": {
      "patterns": [
        {
          "comment": "signal input/output/intermediate name;",
          "match": "\\b(signal)(?:\\s+(input|output))?\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.signal.circom" },
            "2": { "name": "storage.modifier.signal-kind.circom" },
            "3": { "name": "variable.other.signal.circom" }
          }
        }
      ]
    },
    "component-declaration": {
      "patterns": [
        {
          "comment": "component foo = Template(...);",
          "match": "\\b(component)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.component.circom" },
            "2": { "name": "variable.other.component.circom" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.circom",
          "match": "\\b(if|else|for|while|return|do|break|continue)\\b"
        },
        {
          "name": "storage.type.circom",
          "match": "\\b(var|signal|component|template|function|bus|tag|anonymous|parallel|public)\\b"
        },
        {
          "name": "constant.language.circom",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "constraint-operators": {
      "patterns": [
        {
          "comment": "Circom's signal operators: === (equality constraint), <== (assign+constrain), <-- (assign hint), ==> (right-to-left assign+constrain), --> (right-to-left hint)",
          "name": "keyword.operator.constraint.circom",
          "match": "===|<==|<--|==>|-->"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.circom",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.comparison.circom",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.bitwise.circom",
          "match": "&|\\||\\^|~|<<|>>"
        },
        {
          "name": "keyword.operator.arithmetic.circom",
          "match": "\\*\\*|\\+\\+|--|[+\\-*/%]|\\*\\*"
        },
        {
          "name": "keyword.operator.assignment.circom",
          "match": "\\+=|-=|\\*=|/=|%=|\\|=|&=|\\^=|="
        },
        {
          "name": "keyword.operator.ternary.circom",
          "match": "\\?|:"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "comment": "Common circomlib gadgets users import. Highlighted as type so completion-style recognition works.",
          "name": "support.class.circomlib.circom",
          "match": "\\b(Num2Bits|Bits2Num|IsZero|IsEqual|LessThan|LessEqThan|GreaterThan|GreaterEqThan|Poseidon|PoseidonEx|MiMC7|MiMCSponge|Pedersen|BabyAdd|BabyDbl|BabyCheck|BabyPbk|EscalarMulAny|EscalarMulFix|EdDSAPoseidonVerifier|Sign|AliasCheck|CompConstant|Mux1|Mux2|Mux3|Mux4|Switcher|Decoder|Multiplexer|ForceEqualIfEnabled|XOR|AND|OR|NAND|NOR|NOT|MultiAND|MultiOR|BigAdd|BigMul|BigSub|BigMod|SMTVerifier|SMTProcessor)\\b"
        },
        {
          "comment": "Circom intrinsics and log helpers.",
          "name": "support.function.builtin.circom",
          "match": "\\b(log|assert)\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.circom" }
          }
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.comma.circom", "match": "," },
        { "name": "punctuation.terminator.statement.circom", "match": ";" },
        { "name": "punctuation.accessor.circom", "match": "\\." }
      ]
    }
  }
}
